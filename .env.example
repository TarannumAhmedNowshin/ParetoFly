# Copy to .env and fill in real values. .env is git-ignored.

# --- Web search (enrichment) ---
SERPER_API_KEY=
SEARCH_RETRIEVER=googleSerp

# --- Flight offers (primary data source: SerpAPI Google Flights) ---
# The loader also accepts the alias `SerpApi_key`.
SERPAPI_API_KEY=

# --- Azure OpenAI: GPT-5 (narrative / explain node) ---
AZURE_GPT5_ENDPOINT="https://<your-resource>.openai.azure.com/"
AZURE_GPT5_API_KEY=
AZURE_GPT5_API_VERSION="2024-12-01-preview"
AZURE_GPT5_DEPLOYMENT="gpt-5"

# --- Azure OpenAI: GPT-5-mini (intake / clarify / extraction) ---
AZURE_GPT5_MINI_ENDPOINT="https://<your-resource>.cognitiveservices.azure.com/"
AZURE_GPT5_MINI_API_KEY=
AZURE_GPT5_MINI_API_VERSION="2024-12-01-preview"
AZURE_GPT5_MINI_DEPLOYMENT="gpt-5-mini"

# --- API / CORS (frontend origins allowed to call the API) ---
CORS_ALLOW_ORIGINS="http://localhost:3000"

# --- SerpAPI response cache (protects the 250 searches/month free cap) ---
SERPAPI_CACHE_ENABLED=true
SERPAPI_CACHE_DIR=".cache/serpapi"
SERPAPI_CACHE_TTL_SECONDS=21600
